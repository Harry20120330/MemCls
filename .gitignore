# .gitignore for a .NET console project
# Build results
bin/
obj/

# VS / Rider / Editor folders
.vscode/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet packages
*.nupkg
# The packages folder can be ignored if you use NuGet restore
**/packages/*

# Misc
*.log
*.tmp
*.tmp.*
*.old
*.bak
*.orig

# DotNet specific
project.lock.json
project.assets.json
*.cache
*.vspscc
*.vssscc
